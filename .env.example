# FactorialHR API Configuration
# Copy this file to .env and fill in your values

# Required: Your FactorialHR API key
# Get this from: https://app.factorialhr.com → Settings → Integrations → API
FACTORIAL_API_KEY=your_api_key_here

# Optional: Enable debug logging
# Set to 'true' to see detailed request/response logs
# DEBUG=false

# Optional: Factorial API version (advanced)
# Default: 2025-10-01
# Only change if you need to test against a different API version
# FACTORIAL_API_VERSION=2025-10-01

# Optional: Custom timeout in milliseconds
# Default: 30000 (30 seconds)
# FACTORIAL_TIMEOUT_MS=30000

# Optional: Maximum retry attempts for failed requests
# Default: 3
# FACTORIAL_MAX_RETRIES=3

# ============================================================================
# OAuth2 Configuration (Required for document downloads)
# ============================================================================
# Document download tools (download_payslip_pdf, download_employee_document)
# require OAuth2 authentication. Set these if you need to download documents.
#
# Setup steps:
# 1. Create an OAuth2 application in Factorial (Settings → Integrations → OAuth2)
# 2. Complete the authorization flow to get a refresh token
# 3. Set the values below
#
# See README.md for detailed setup instructions.

# OAuth2 Client ID from your Factorial OAuth2 application
# FACTORIAL_OAUTH_CLIENT_ID=your_oauth_client_id

# OAuth2 Client Secret from your Factorial OAuth2 application
# FACTORIAL_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# OAuth2 Refresh Token (obtained after completing authorization flow)
# Note: Refresh tokens expire after 1 week - you'll need to re-authorize if expired
# FACTORIAL_OAUTH_REFRESH_TOKEN=your_refresh_token
